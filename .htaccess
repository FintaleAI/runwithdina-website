ErrorDocument 404 /404.html

# ============================================================
# GZIP COMPRESSION — reduces file sizes by 60-80%
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ============================================================
# BROWSER CACHING — stops re-downloading unchanged files
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # Images — cache for 1 month
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"

  # CSS & JS — cache for 1 week
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"

  # HTML — cache for 1 hour (so updates show quickly)
  ExpiresByType text/html "access plus 1 hour"

  # Fonts
  ExpiresByType font/woff2 "access plus 1 month"
  ExpiresByType font/woff "access plus 1 month"
</IfModule>

# ============================================================
# FORCE HTTPS
# ============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Remove index.html from URLs — clean URLs
  RewriteCond %{THE_REQUEST} /index\.html [NC]
  RewriteRule ^(.*)index\.html$ /$1 [L,R=301]
</IfModule>

# ============================================================
# SECURITY HEADERS
# ============================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), camera=(), microphone=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ============================================================
# BLOCK DIRECTORY BROWSING
# ============================================================
Options -Indexes

# ============================================================
# BLOCK ACCESS TO SENSITIVE FILES
# ============================================================
<FilesMatch "\.(git|env|log|bak|sql|old)$">
  Order allow,deny
  Deny from all
</FilesMatch>
